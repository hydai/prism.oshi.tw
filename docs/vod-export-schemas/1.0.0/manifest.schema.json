{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.oshi.tw/vod/v1/schemas/1.0.0/manifest.schema.json",
  "title": "Oshi VOD Export v1-Compatible Manifest",
  "description": "Machine-readable v1 baseline contract for the public VOD export manifest. Compatible v1 minor versions may add safely ignorable properties. Cross-field snapshot URL/hash equality and snapshot count equality require the consumer checks documented in the public guide.",
  "type": "object",
  "required": [
    "schemaVersion",
    "snapshotUrl",
    "sha256",
    "publishedAt",
    "uncompressedBytes",
    "counts"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "#/$defs/v1SchemaVersion"
    },
    "snapshotUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://[^/?#@:]+/vod/v1/snapshots/[0-9a-f]{64}\\.json$",
      "description": "Absolute URL on a configured trusted artifact origin. Its filename hash must equal the adjacent sha256 property."
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 of the exact decoded, uncompressed snapshot bytes."
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "uncompressedBytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10485760
    },
    "counts": {
      "type": "object",
      "required": [
        "streamers",
        "vods",
        "performances"
      ],
      "properties": {
        "streamers": {
          "type": "integer",
          "minimum": 0,
          "maximum": 500
        },
        "vods": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "performances": {
          "type": "integer",
          "minimum": 0,
          "maximum": 50000
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "v1SchemaVersion": {
      "type": "string",
      "pattern": "^1\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"
    }
  }
}
