{
  "name": "prism-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create oshi-prism-db",
    "db:migrate": "wrangler d1 execute oshi-prism-db --remote --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute oshi-prism-db --local --file=schema.sql",
    "db:seed:local": "npx tsx seed.ts --local",
    "typecheck": "tsc --noEmit",
    "test:helpers": "npx tsx src/helpers.test.ts",
    "test:itunes": "npx tsx src/itunes.test.ts",
    "test:discord": "npx tsx shared/discord.test.ts",
    "test:db": "npx tsx src/db.test.ts",
    "check": "npm run typecheck && npm run test:helpers && npm run test:itunes && npm run test:discord && npm run test:db"
  },
  "dependencies": {
    "hono": "^4.12.22"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.93.1"
  }
}
