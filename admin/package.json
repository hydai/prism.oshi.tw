{
  "name": "prism-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create oshi-prism-db",
    "db:migrate": "wrangler d1 execute oshi-prism-db --remote --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute oshi-prism-db --local --file=schema.sql",
    "db:seed:local": "npx tsx seed.ts --local",
    "typecheck": "tsc --noEmit",
    "test:helpers": "npx tsx src/helpers.test.ts",
    "test:itunes": "npx tsx src/itunes.test.ts",
    "test:discord": "npx tsx shared/discord.test.ts",
    "test:nova-url-safety": "npx tsx shared/nova-url-safety.test.ts",
    "test:db": "npx tsx src/db.test.ts",
    "test:auth": "npx tsx src/auth.test.ts",
    "test:authz": "npx tsx src/authz.test.ts",
    "test:nova-url-routes": "npx tsx src/nova-url-safety-routes.test.ts",
    "test:vod-export-schema": "sh migrations/test_vod_export_schema.sh",
    "test:vod-export-core": "npx tsx src/vod-export/core.test.ts",
    "test:vod-export-source": "npx tsx src/vod-export/source.test.ts",
    "test:vod-export-api": "npx tsx src/vod-export/api.test.ts",
    "test:vod-export-publication": "npx tsx src/vod-export/publication.test.ts",
    "test:vod-export-maintenance": "npx tsx src/vod-export/maintenance.test.ts",
    "test:youtube-verification": "npx tsx src/youtube-verification.test.ts",
    "check": "npm run typecheck && npm run test:helpers && npm run test:itunes && npm run test:discord && npm run test:nova-url-safety && npm run test:db && npm run test:auth && npm run test:authz && npm run test:nova-url-routes && npm run test:youtube-verification && npm run test:vod-export-schema && npm run test:vod-export-core && npm run test:vod-export-source && npm run test:vod-export-api && npm run test:vod-export-publication && npm run test:vod-export-maintenance"
  },
  "dependencies": {
    "hono": "^4.12.29"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  }
}
