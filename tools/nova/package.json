{
  "name": "oshi-prism-nova",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create oshi-prism-nova",
    "db:migrate": "wrangler d1 execute oshi-prism-nova --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute oshi-prism-nova --local --file=schema.sql",
    "typecheck": "tsc --noEmit",
    "test:video-info": "npx tsx src/index.test.ts",
    "test:vod-page": "npx tsx src/vod-page.test.ts",
    "check": "npm run typecheck && npm run test:video-info && npm run test:vod-page"
  },
  "dependencies": {
    "hono": "^4.12.22"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.93.1"
  }
}
