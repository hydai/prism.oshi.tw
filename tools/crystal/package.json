{
  "name": "oshi-prism-crystal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create oshi-crystal",
    "db:migrate": "wrangler d1 execute oshi-crystal --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute oshi-crystal --local --file=schema.sql",
    "test": "tsx src/validate.test.ts && tsx src/qa-page.test.ts && tsx src/similar.test.ts && tsx src/qa-api.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.22"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.93.1"
  }
}
