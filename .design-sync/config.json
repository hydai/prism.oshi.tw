{
  "pkg": "prism-oshi-tw",
  "globalName": "PrismOshi",
  "projectId": "770b7156-2440-4b15-81af-2ed85c849ba0",
  "shape": "package",
  "entry": ".design-sync/.cache/ds-entry.mjs",
  "srcDir": "app/components",
  "tsconfig": ".design-sync/tsconfig.sync.json",
  "buildCmd": "node .design-sync/gen-entry.mjs && npx tailwindcss -c ./tailwind.config.ts -i ./app/globals.css -o .design-sync/.cache/compiled.css",
  "cssEntry": ".design-sync/.cache/compiled.css",
  "guidelinesGlob": [],
  "readmeHeader": ".design-sync/conventions.md",
  "extraEntries": ["./.design-sync/preview-harness.tsx"],
  "provider": { "component": "PreviewProvider" },
  "overrides": {
    "AlbumArt": { "cardMode": "column" },
    "NowPlayingModal": { "cardMode": "single", "viewport": "960x880" },
    "QueuePanel": { "cardMode": "single", "viewport": "560x560" },
    "PlaylistPanel": { "cardMode": "single", "viewport": "600x460" },
    "LikedSongsPanel": { "cardMode": "single", "viewport": "560x560" },
    "RecentlyPlayedPanel": { "cardMode": "single", "viewport": "560x600" },
    "CreatePlaylistDialog": { "cardMode": "single", "viewport": "640x560" },
    "BottomSheet": { "cardMode": "single", "viewport": "560x700" },
    "MiniPlayer": { "cardMode": "single", "viewport": "1040x220" },
    "AddToPlaylistDropdown": { "cardMode": "single", "viewport": "440x560" },
    "ProgressBar": { "cardMode": "column" },
    "NowPlayingControls": { "cardMode": "column" },
    "MobileSearchRow": { "cardMode": "column" },
    "TimelineRow": { "cardMode": "column" },
    "Toast": { "cardMode": "single", "primaryStory": "AddedToPlaylist" }
  },
  "componentSrcMap": {
    "AddToPlaylistDropdown": "app/components/AddToPlaylistDropdown.tsx",
    "AlbumArt": "app/components/AlbumArt.tsx",
    "BottomSheet": "app/components/BottomSheet.tsx",
    "CreatePlaylistDialog": "app/components/CreatePlaylistDialog.tsx",
    "DiscordIcon": "app/components/DiscordIcon.tsx",
    "GlobalProviders": "app/components/GlobalProviders.tsx",
    "LikedSongsPanel": "app/components/LikedSongsPanel.tsx",
    "MiniPlayer": "app/components/MiniPlayer.tsx",
    "MobileSearchRow": "app/components/MobileSearchRow.tsx",
    "NowPlayingControls": "app/components/NowPlayingControls.tsx",
    "NowPlayingModal": "app/components/NowPlayingModal.tsx",
    "PerStreamerProviders": "app/components/PerStreamerProviders.tsx",
    "PlaylistPanel": "app/components/PlaylistPanel.tsx",
    "ProgressBar": "app/components/ProgressBar.tsx",
    "QueuePanel": "app/components/QueuePanel.tsx",
    "RecentlyPlayedPanel": "app/components/RecentlyPlayedPanel.tsx",
    "RecentlyPlayedTracker": "app/components/RecentlyPlayedTracker.tsx",
    "SidebarNav": "app/components/SidebarNav.tsx",
    "SongCard": "app/components/SongCard.tsx",
    "ThemeToggle": "app/components/ThemeToggle.tsx",
    "TimelineRow": "app/components/TimelineRow.tsx",
    "Toast": "app/components/Toast.tsx",
    "UpNextSection": "app/components/UpNextSection.tsx",
    "VolumeControl": "app/components/VolumeControl.tsx",
    "YouTubePlayerContainer": "app/components/YouTubePlayerContainer.tsx"
  }
}
